generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Taxista {
  id             String        @id @default(uuid())
  nombreCompleto String
  telefono       String        @unique
  passwordHash   String
  estado         EstadoTaxista
  creadoEn       DateTime      @default(now())

  telefonoVerificado         Boolean   @default(false)
  codigoVerificacion         String?
  codigoVerificacionExpiraEn DateTime?
  ultimoEnvioCodigo          DateTime?

  lat                    Float?
  lng                    Float?
  ubicacionActualizadaEn DateTime?

  paradaId      String?
  enParadaDesde DateTime?
  parada        Parada?   @relation("TaxistasEnParada", fields: [paradaId], references: [id])

  vehiculo     Vehiculo?
  asignaciones AsignacionSolicitud[]
  ofertas      OfertaSolicitud[]

  expoPushToken         String?
  objetosPerdidos ObjetoPerdido[]
}

model Vehiculo {
  id           String                @id @default(uuid())
  taxistaId    String                @unique
  numeroTaxi   String                @unique
  matricula    String?
  modelo       String?
  color        String?
  creadoEn     DateTime              @default(now())
  asignaciones AsignacionSolicitud[]
  taxista      Taxista               @relation(fields: [taxistaId], references: [id], onDelete: Cascade)
}

model SolicitudViaje {
  id                String           @id @default(uuid())
  nombreCliente     String
  telefonoCliente   String
  direccionRecogida String
  direccionBase        String?
  referenciaRecogida   String?
  estado            EstadoSolicitud
  origen            OrigenSolicitud?
  creadaEn          DateTime         @default(now())
  confirmadaEn      DateTime?

  latRecogida Float?
  lngRecogida Float?

  paradaSugeridaId String?
  paradaSugerida   Parada? @relation("ParadaSugeridaSolicitud", fields: [paradaSugeridaId], references: [id])

  asignacion AsignacionSolicitud?
  ofertas    OfertaSolicitud[]
}

model OfertaSolicitud {
  id               String         @id @default(uuid())
  solicitudViajeId String
  taxistaId        String
  estado           EstadoOferta   @default(pendiente)
  ofrecidaEn       DateTime       @default(now())
  respondidaEn     DateTime?
  solicitudViaje   SolicitudViaje @relation(fields: [solicitudViajeId], references: [id], onDelete: Cascade)
  taxista          Taxista        @relation(fields: [taxistaId], references: [id], onDelete: Cascade)
}

model AsignacionSolicitud {
  id               String         @id @default(uuid())
  solicitudViajeId String         @unique
  taxistaId        String
  vehiculoId       String
  asignadaEn       DateTime       @default(now())
  solicitudViaje   SolicitudViaje @relation(fields: [solicitudViajeId], references: [id], onDelete: Cascade)
  taxista          Taxista        @relation(fields: [taxistaId], references: [id], onDelete: Cascade)
  vehiculo         Vehiculo       @relation(fields: [vehiculoId], references: [id], onDelete: Cascade)
}

model Parada {
  id        String   @id @default(uuid())
  nombre    String   @unique
  direccion String?
  lat       Float
  lng       Float
  activa    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  taxistas             Taxista[]        @relation("TaxistasEnParada")
  solicitudesSugeridas SolicitudViaje[] @relation("ParadaSugeridaSolicitud")
}

model ObjetoPerdido {
  id             String   @id @default(uuid())
  descripcion    String
  observaciones  String?
  estado         EstadoObjetoPerdido @default(pendiente)
  fechaHallazgo  DateTime @default(now())
  creadoEn       DateTime @default(now())

  taxistaId      String
  taxista        Taxista  @relation(fields: [taxistaId], references: [id], onDelete: Cascade)
}

enum EstadoObjetoPerdido {
  pendiente
  entregado
}

enum EstadoTaxista {
  desconectado
  disponible
  ocupado
}

enum EstadoSolicitud {
  pendiente
  ofertada
  asignada
  sin_taxista
  cancelada
  completada
}

enum EstadoOferta {
  pendiente
  aceptada
  rechazada
  expirada
}

enum OrigenSolicitud {
  llamada_ia
  operador
  web
}
